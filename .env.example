# Docker project name — sets the prefix for all container names (e.g. websidian-sync, websidian-caddy)
COMPOSE_PROJECT_NAME=websidian

# Your deployment domain — used by docker-compose to derive all service URLs
DOMAIN=your-domain.com

# Sync / API server
DB_PATH=/data/websidian.db
BETTER_AUTH_SECRET=<min-32-char-random-string>
BETTER_AUTH_URL=https://your-domain.com
WEB_URL=https://your-domain.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# AI bot (Yjs WebSocket only — keeps AI edits visible as "AI Assistant" presence)
AI_BOT_TOKEN=<strong-random-token>

# MCP server
MCP_PORT=3100
MCP_BEARER=<strong-random-token>
# Public URL of the MCP server — included in oauth-protected-resource metadata
MCP_URL=https://your-domain.com/mcp

# Web build-time vars — derived automatically from DOMAIN in the web Dockerfile
# Only needed if building the web app outside of docker-compose
VITE_SYNC_URL=wss://your-domain.com
VITE_API_URL=https://your-domain.com
