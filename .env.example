# Sync / API server
BETTER_AUTH_SECRET=replace-with-a-real-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:1235
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Web app URL — used by /oauth/authorize to redirect unauthenticated users to login
WEB_URL=http://localhost:5173

# AI bot (Yjs WebSocket only — keeps AI edits visible as "AI Assistant" presence)
AI_BOT_TOKEN=replace-with-strong-random-token

# MCP server
MCP_PORT=3100
# Public URL of the MCP server — included in oauth-protected-resource metadata
MCP_URL=http://localhost:3100
# Optional dev bypass: if set, requests with this exact Bearer token skip OAuth validation
MCP_BEARER=
